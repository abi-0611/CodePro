---
const logos = [
  '[LOGO_GOOGLE]',
  '[LOGO_AMAZON]',
  '[LOGO_MICROSOFT]',
  '[LOGO_META]',
  '[LOGO_APPLE]',
  '[LOGO_NETFLIX]',
  '[LOGO_IBM]',
  '[LOGO_TCS]',
];
---
<div class="overflow-hidden whitespace-nowrap relative py-8">
  <div class="absolute inset-y-0 left-0 w-16 sm:w-32 bg-gradient-to-r from-[var(--color-surface-alt)] to-transparent z-10"></div>
  <div class="absolute inset-y-0 right-0 w-16 sm:w-32 bg-gradient-to-l from-[var(--color-surface-alt)] to-transparent z-10"></div>
  
  <div class="inline-flex animate-marquee items-center gap-16">
    {[...logos, ...logos].map((logo) => (
      <div class="text-xl sm:text-2xl font-bold text-[var(--color-muted)] opacity-50 hover:opacity-100 transition-opacity">
        {logo}
      </div>
    ))}
  </div>
</div>

<style>
  .animate-marquee {
    animation: marquee 30s linear infinite;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-marquee {
      animation: none;
      transform: none;
    }
  }
</style>
