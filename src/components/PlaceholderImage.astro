---
interface Props {
  label: string;
  width: number;
  height: number;
  className?: string;
}
const { label, width, height, className = "" } = Astro.props;
---
<div 
  class={`flex items-center justify-center text-center bg-[var(--color-surface-alt-val)] text-[var(--color-muted-val)] rounded-[var(--radius-card)] ${className} border border-dashed border-[var(--color-border-val)] shadow-none p-3 sm:p-4`}
  style={`aspect-ratio: ${width} / ${height};`}
  role="img"
  aria-label={label}
>
  <span class="font-mono text-[11px] sm:text-xs leading-snug break-words max-w-[42ch] opacity-80">{label}</span>
</div>
