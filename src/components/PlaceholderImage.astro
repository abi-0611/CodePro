---
interface Props {
  label: string;
  width: number;
  height: number;
  className?: string;
}
const { label, width, height, className = "" } = Astro.props;
---
<div 
  class={`bg-[var(--color-surface-alt-val)] border-2 border-dashed border-[var(--color-border-val)] flex items-center justify-center text-[var(--color-muted-val)] text-center p-4 rounded-lg ${className}`}
  style={`aspect-ratio: ${width} / ${height};`}
  role="img"
  aria-label={label}
>
  <span class="font-mono text-sm">{label}</span>
</div>
