---
import SectionHeader from './SectionHeader.astro';

const steps = [
  { num: '01', icon: '📋', title: 'Choose Your Course', desc: 'Browse our catalogue and pick the program that matches your career goal. Not sure? Book a free demo call.' },
  { num: '02', icon: '🧑‍🏫', title: 'Learn with Mentors', desc: 'Attend mentor-led sessions and practice every concept with guided exercises.' },
  { num: '03', icon: '🛠️', title: 'Build Projects', desc: 'Work on real portfolio projects and get feedback to improve your code.' },
  { num: '04', icon: '🎯', title: 'Get Job Ready', desc: 'Refine your resume, take mock interviews, and get placement support.' },
];
---
<section class="py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionHeader
        eyebrow="How it works"
        title="A clear path from learning to hiring"
        description="A practical flow designed to keep you consistent, supported, and job-ready."
      />
    </div>

    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((s, i) => (
        <div class={`card p-6 card-lift reveal delay-${Math.min(5, i + 1)}`}>
          <div class="flex items-center justify-between mb-6">
            <div class="text-3xl" aria-hidden="true">{s.icon}</div>
            <div class="text-xs font-bold tracking-widest text-[var(--color-primary-val)]">{s.num}</div>
          </div>
          <h3 class="text-lg font-bold font-heading text-[var(--color-ink-val)] mb-2">{s.title}</h3>
          <p class="text-sm text-[var(--color-muted-val)]">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
