---
import { Instagram, Facebook, Youtube, Linkedin, MapPin, Phone, Mail, MessageCircle } from 'lucide-react';
import {
  INSTITUTE_NAME,
  SITE_TAGLINE,
  ADDRESS_PLACEHOLDER,
  CONTACT_PHONE,
  CONTACT_EMAIL,
  SOCIAL_INSTAGRAM_URL,
  SOCIAL_FACEBOOK_URL,
  SOCIAL_YOUTUBE_URL,
  SOCIAL_LINKEDIN_URL,
  WHATSAPP_URL,
} from '../utils/consts';

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const withBase = (path: string) => `${baseUrl}${path.replace(/^\/+/, '')}`;

const isBracketPlaceholder = (value: unknown) =>
  typeof value === 'string' && /^\[[^\[\]\n]{2,}\]$/.test(value.trim());

const safeText = (value: unknown, fallback: string) =>
  typeof value === 'string' && value.trim() && !isBracketPlaceholder(value) ? value : fallback;

const instituteName = safeText(INSTITUTE_NAME, 'CodePro');
const siteTagline = safeText(SITE_TAGLINE, 'Practical training for modern careers.');

const address = !isBracketPlaceholder(ADDRESS_PLACEHOLDER) ? ADDRESS_PLACEHOLDER : null;
const phone = !isBracketPlaceholder(CONTACT_PHONE) ? CONTACT_PHONE : null;
const email = !isBracketPlaceholder(CONTACT_EMAIL) ? CONTACT_EMAIL : null;

const instagramUrl = !isBracketPlaceholder(SOCIAL_INSTAGRAM_URL) ? SOCIAL_INSTAGRAM_URL : null;
const facebookUrl = !isBracketPlaceholder(SOCIAL_FACEBOOK_URL) ? SOCIAL_FACEBOOK_URL : null;
const youtubeUrl = !isBracketPlaceholder(SOCIAL_YOUTUBE_URL) ? SOCIAL_YOUTUBE_URL : null;
const linkedinUrl = !isBracketPlaceholder(SOCIAL_LINKEDIN_URL) ? SOCIAL_LINKEDIN_URL : null;
const whatsappUrl = !isBracketPlaceholder(WHATSAPP_URL) ? WHATSAPP_URL : null;

const contactHref = withBase('contact/');
const links = {
  home: withBase(''),
  courses: withBase('courses/'),
  about: withBase('about/'),
  contact: contactHref,
};
---

<footer class="bg-[var(--footer-bg-val)] text-[var(--footer-fg-val)] pt-16 pb-8 border-t border-[var(--footer-border-val)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      
      {/* Col 1 - Brand */}
      <div class="flex flex-col gap-4 reveal">
        <div class="text-2xl font-bold font-heading text-[var(--footer-heading-val)]">
          {instituteName}
        </div>
        <p class="text-sm leading-relaxed">
          {siteTagline}
        </p>
        {(instagramUrl || facebookUrl || youtubeUrl || linkedinUrl) && (
          <div class="flex items-center gap-4 mt-2">
            {instagramUrl && (
              <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-primary-val)] transition-colors hover:scale-125 transition-transform" aria-label="Instagram">
                <Instagram class="w-5 h-5" />
              </a>
            )}
            {facebookUrl && (
              <a href={facebookUrl} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-primary-val)] transition-colors hover:scale-125 transition-transform" aria-label="Facebook">
                <Facebook class="w-5 h-5" />
              </a>
            )}
            {youtubeUrl && (
              <a href={youtubeUrl} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-primary-val)] transition-colors hover:scale-125 transition-transform" aria-label="YouTube">
                <Youtube class="w-5 h-5" />
              </a>
            )}
            {linkedinUrl && (
              <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-primary-val)] transition-colors hover:scale-125 transition-transform" aria-label="LinkedIn">
                <Linkedin class="w-5 h-5" />
              </a>
            )}
          </div>
        )}
      </div>

      {/* Col 2 - Corporate Office */}
      <div class="flex flex-col gap-4 reveal delay-1">
        <h3 class="text-lg font-semibold text-[var(--footer-heading-val)] font-heading">Contact</h3>
        <ul class="flex flex-col gap-3 text-sm">
          <li class="flex items-start gap-3">
            <MapPin class="w-5 h-5 shrink-0 text-[var(--color-primary-val)]" />
            {address ? <span>{address}</span> : <a href={contactHref} class="hover:text-[var(--color-primary-val)] transition-colors">Get directions & center details</a>}
          </li>
          <li class="flex items-center gap-3">
            <Phone class="w-5 h-5 shrink-0 text-[var(--color-primary-val)]" />
            {phone ? <a href={`tel:${phone}`} class="hover:text-[var(--color-primary-val)] transition-colors">{phone}</a> : <a href={contactHref} class="hover:text-[var(--color-primary-val)] transition-colors">Request a call back</a>}
          </li>
          <li class="flex items-center gap-3">
            <Mail class="w-5 h-5 shrink-0 text-[var(--color-primary-val)]" />
            {email ? <a href={`mailto:${email}`} class="hover:text-[var(--color-primary-val)] transition-colors">{email}</a> : <a href={contactHref} class="hover:text-[var(--color-primary-val)] transition-colors">Send an enquiry</a>}
          </li>
        </ul>
      </div>

      {/* Col 3 - For Students */}
      <div class="flex flex-col gap-4 reveal delay-2">
        <h3 class="text-lg font-semibold text-[var(--footer-heading-val)] font-heading">Quick links</h3>
        <ul class="flex flex-col gap-2 text-sm">
          <li><a href={links.home} class="hover:text-[var(--color-primary-val)] transition-colors">Home</a></li>
          <li><a href={links.courses} class="hover:text-[var(--color-primary-val)] transition-colors">Courses</a></li>
          <li><a href={links.about} class="hover:text-[var(--color-primary-val)] transition-colors">About</a></li>
          <li><a href={links.contact} class="hover:text-[var(--color-primary-val)] transition-colors">Contact</a></li>
        </ul>
      </div>

      {/* Col 4 - For Business */}
      <div class="flex flex-col gap-4 reveal delay-3">
        <h3 class="text-lg font-semibold text-[var(--footer-heading-val)] font-heading">Programs</h3>
        <ul class="flex flex-col gap-2 text-sm">
          <li><a href={links.courses} class="hover:text-[var(--color-primary-val)] transition-colors">Career programs</a></li>
          <li><a href={links.contact} class="hover:text-[var(--color-primary-val)] transition-colors">Workshops (enquire)</a></li>
          <li><a href={links.contact} class="hover:text-[var(--color-primary-val)] transition-colors">Internships (enquire)</a></li>
        </ul>
      </div>

    </div>

    {/* Bottom Bar */}
    <div class="pt-8 border-t border-[var(--footer-border-val)] flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-[var(--footer-subtle-val)]">
      <p>&copy; {new Date().getFullYear()} {instituteName}. All rights reserved.</p>
      <div class="flex gap-4">
        <a href={links.about} class="hover:text-[var(--footer-heading-val)] transition-colors">About</a>
        <a href={links.contact} class="hover:text-[var(--footer-heading-val)] transition-colors">Contact</a>
      </div>
    </div>
  </div>

  {/* Floating WhatsApp Button */}
  {whatsappUrl && (
    <a 
      href={whatsappUrl} 
      target="_blank" 
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 bg-[var(--color-primary-val)] text-white p-4 rounded-full shadow-lg hover:bg-[var(--color-primary-dark-val)] hover:scale-110 transition-all z-50 flex items-center justify-center focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-[var(--color-primary-val)]"
      aria-label="Chat on WhatsApp"
    >
      <MessageCircle class="w-6 h-6" />
    </a>
  )}
</footer>
