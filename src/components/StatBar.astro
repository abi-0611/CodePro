---
import { BookOpen, Handshake, UserCheck, Users } from 'lucide-react';
import { getAllCourses } from '../lib/api';
import AnimatedCounter from './AnimatedCounter.astro';

export interface Props {
  stats?: {
    value: number | string;
    suffix: string;
    label: string;
    icon: any;
  }[];
  wrapperClass?: string;
}

const courses = await getAllCourses();
const courseCount = courses.length;

const defaultStats = [
  { value: courseCount, suffix: '', label: 'Courses', icon: BookOpen },
  { value: 5, suffix: '', label: 'Learners', icon: Users },
  { value: 3, suffix: '', label: 'Mentors', icon: UserCheck },
  { value: 2, suffix: '', label: 'Partners', icon: Handshake },
];

const { stats = defaultStats, wrapperClass = '' } = Astro.props;

const accentClasses = [
  {
    container: 'bg-amber-500/15 text-amber-700 dark:text-amber-300',
    dot: 'bg-amber-500',
  },
  {
    container: 'bg-blue-500/12 text-blue-700 dark:text-blue-300',
    dot: 'bg-blue-500',
  },
  {
    container: 'bg-emerald-500/12 text-emerald-700 dark:text-emerald-300',
    dot: 'bg-emerald-500',
  },
  {
    container: 'bg-violet-500/12 text-violet-700 dark:text-violet-300',
    dot: 'bg-violet-500',
  },
];

const computedStats = stats.map((stat) => ({
  ...stat,
  isNumeric: typeof stat.value === 'number' && Number.isFinite(stat.value),
}));
---
<section class={`py-12 border-y border-[var(--color-border-val)] relative overflow-hidden ${wrapperClass}`}>
  <div class="absolute inset-0 pointer-events-none opacity-[0.35]" aria-hidden="true"
    style="background-image: radial-gradient(circle at 20% 20%, color-mix(in srgb, var(--color-primary-val) 18%, transparent), transparent 40%), radial-gradient(circle at 80% 10%, rgba(59,130,246,0.12), transparent 45%), radial-gradient(circle at 50% 90%, rgba(16,185,129,0.12), transparent 45%);"
  ></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="glass rounded-[var(--radius-card)] px-2 py-6 sm:px-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center" id="stats-container">
      {computedStats.map((stat, index) => {
        const accent = accentClasses[index % accentClasses.length];
        return (
        <div class={`flex flex-col items-center p-4 reveal delay-${Math.min(5, index + 1)}`}>
          <div class={`w-12 h-12 rounded-full flex items-center justify-center mb-4 shadow-sm ${accent.container}`}>
            {stat.icon ? <stat.icon className="w-6 h-6" /> : <span class={`w-3 h-3 rounded-full ${accent.dot}`}></span>}
          </div>
          <div class="text-5xl sm:text-6xl font-bold font-heading text-[var(--color-ink-val)] mb-2 flex items-center justify-center">
            {stat.isNumeric ? (
              <AnimatedCounter value={Number(stat.value)} suffix={stat.suffix} />
            ) : (
              <span class="stat-static">{stat.value}{stat.suffix}</span>
            )}
          </div>
          <div class="text-sm font-medium text-[var(--color-muted-val)] uppercase tracking-wider">{stat.label}</div>
        </div>
        );
      })}
      </div>
    </div>
  </div>
</section>
