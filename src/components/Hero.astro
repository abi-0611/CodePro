---
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---
<section class="grid-overlay relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden bg-gradient-to-b from-[var(--hero-gradient-from-val)] to-[var(--hero-gradient-to-val)]">
  <div class="absolute top-0 right-0 w-96 h-96 rounded-full blur-[80px] bg-amber-500/10 pointer-events-none -translate-y-1/4 translate-x-1/4 z-0"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full blur-[60px] bg-blue-500/8 pointer-events-none translate-y-1/4 -translate-x-1/4 z-0"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 gap-12 items-center">
      <div class="text-left">
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-[var(--color-surface-alt-val)] border border-[var(--color-border-val)] text-sm font-medium text-[var(--color-ink-val)] mb-6">
          Get trained by Industry Experts via
        </div>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold font-heading tracking-tight mb-6 break-words hyphens-auto">
          <span class="text-[var(--color-ink-val)]">Classroom Training or</span><br/>
          <span class="text-[var(--color-primary-val)]">Instructor-led Live Online</span>
        </h1>
        <p class="text-lg sm:text-xl text-[var(--color-muted-val)] mb-8 max-w-2xl leading-relaxed">
          with 100% Placement Support
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#enquiry-section" class="button primary text-lg px-8 py-4 rounded-full">
            Enquire Now
          </a>
          <a href={`${baseUrl}courses/`} class="button secondary text-lg px-8 py-4 rounded-full">
            View Courses
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
