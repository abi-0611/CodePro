---
import { Star } from 'lucide-react';

interface Props {
  title: string;
  shortDescription?: string;
  duration?: string;
  mode?: string;
  level?: string;
  slug?: string;
  badge?: string;
  icon?: string;
  category?: string;
}

const { title, shortDescription, duration, mode, level, slug, badge, icon, category } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const durationNumber = typeof duration === 'string' ? Number.parseInt(duration, 10) : Number.NaN;
const durationScale = Number.isFinite(durationNumber)
  ? Math.min(1, Math.max(0.25, durationNumber / 12))
  : 0.66;
---
<a href={slug ? `${baseUrl}courses/${slug}/` : '#'} class="block group h-full course-card card-lift" data-category={category}>
  <div class="card p-6 h-full flex flex-col relative overflow-hidden border-t-4 border-t-[var(--color-primary)]">

    {icon && (
      <div class="text-4xl mb-2">{icon}</div>
    )}

    <div class="flex flex-wrap gap-2 mb-4">
      {badge && (
        <span class={badge === 'Popular'
          ? 'inline-flex items-center gap-1 px-2 py-1 rounded-full text-[10px] font-semibold bg-amber-500/10 text-amber-700 dark:text-amber-300 border border-amber-500/30 uppercase tracking-wider'
          : 'inline-flex items-center px-2 py-1 rounded-full text-[10px] font-semibold bg-[var(--color-primary)]/10 text-[var(--color-primary)] border border-[var(--color-primary)]/20 uppercase tracking-wider'
        }>
          {badge === 'Popular' && <Star class="w-3 h-3 fill-current" />}
          {badge}
        </span>
      )}
      {duration && <span class="inline-flex items-center px-2 py-1 rounded-full text-[10px] font-semibold bg-[var(--color-surface-alt)] text-[var(--color-muted)] border border-[var(--color-border)] uppercase tracking-wider">{duration}</span>}
      {mode && <span class="inline-flex items-center px-2 py-1 rounded-full text-[10px] font-semibold bg-[var(--color-surface-alt)] text-[var(--color-muted)] border border-[var(--color-border)] uppercase tracking-wider">{mode}</span>}
      {level && <span class="inline-flex items-center px-2 py-1 rounded-full text-[10px] font-semibold bg-[var(--color-surface-alt)] text-[var(--color-muted)] border border-[var(--color-border)] uppercase tracking-wider">{level}</span>}
    </div>

    <h3 class="text-xl font-bold font-heading text-[var(--color-ink)] mb-3 group-hover:text-[var(--color-primary)] transition-colors">{title}</h3>

    {shortDescription && <p class="text-[var(--color-muted)] text-sm mb-6 flex-grow line-clamp-2">{shortDescription}</p>}

    <div class="mt-auto pt-4 border-t border-[var(--color-border)] flex items-center text-[var(--color-primary)] font-medium text-sm group-hover:underline underline-offset-4">
      Know More <span class="ml-1 transition-transform group-hover:translate-x-1">→</span>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-1 bg-[var(--color-border-val)] rounded-b-[var(--radius-card)]">
      <div
        class="h-full rounded-b-[var(--radius-card)] skill-bar-fill"
        style={`--target-scale: ${durationScale};`}
        aria-hidden="true"
      ></div>
    </div>
  </div>
</a>
