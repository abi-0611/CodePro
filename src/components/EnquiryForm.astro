---
import { getAllCourses } from '../lib/api';
import { randomUUID } from 'node:crypto';

const courses = await getAllCourses();
const uid = randomUUID();
---
<div class="relative" data-enquiry-root={uid}>
  <form class="flex flex-col gap-5" data-enquiry-form novalidate>
    <div class="flex flex-col gap-1">
      <label for={`${uid}-name`} class="text-sm font-semibold text-[var(--color-ink)]">Full Name <span class="text-red-500">*</span></label>
      <input type="text" id={`${uid}-name`} name="name" required class="w-full px-4 py-3 rounded-[var(--radius-input)] border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-ink)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-all" placeholder="Enter your full name" />
      <span class="error-message text-red-500 text-xs hidden">Please enter your full name.</span>
    </div>
    
    <div class="flex flex-col gap-1">
      <label for={`${uid}-email`} class="text-sm font-semibold text-[var(--color-ink)]">Email Address <span class="text-red-500">*</span></label>
      <input type="email" id={`${uid}-email`} name="email" required pattern="[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$" class="w-full px-4 py-3 rounded-[var(--radius-input)] border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-ink)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-all" placeholder="Enter your email address" />
      <span class="error-message text-red-500 text-xs hidden">Please enter a valid email address.</span>
    </div>

    <div class="flex flex-col gap-1">
      <label for={`${uid}-phone`} class="text-sm font-semibold text-[var(--color-ink)]">Phone Number <span class="text-red-500">*</span></label>
      <input type="tel" id={`${uid}-phone`} name="phone" required pattern="[0-9]{10}" class="w-full px-4 py-3 rounded-[var(--radius-input)] border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-ink)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-all" placeholder="Enter 10 digit phone number" />
      <span class="error-message text-red-500 text-xs hidden">Please enter a valid 10-digit phone number.</span>
    </div>
    
    <div class="flex flex-col gap-1">
      <label for={`${uid}-course`} class="text-sm font-semibold text-[var(--color-ink)]">Course Interested <span class="text-red-500">*</span></label>
      <select id={`${uid}-course`} name="course" required class="w-full px-4 py-3 rounded-[var(--radius-input)] border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-ink)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-all appearance-none">
        <option value="" disabled selected>Select a course</option>
        {courses.map((course: any) => (
          <option value={course.slug}>{course.title}</option>
        ))}
      </select>
      <span class="error-message text-red-500 text-xs hidden">Please select a course.</span>
    </div>

    <div class="flex flex-col gap-1">
      <label for={`${uid}-mode`} class="text-sm font-semibold text-[var(--color-ink)]">Preferred Mode <span class="text-red-500">*</span></label>
      <select id={`${uid}-mode`} name="mode" required class="w-full px-4 py-3 rounded-[var(--radius-input)] border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-ink)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-all appearance-none">
        <option value="" disabled selected>Select training mode</option>
        <option value="online">Online</option>
        <option value="offline">Offline</option>
        <option value="hybrid">Hybrid</option>
      </select>
      <span class="error-message text-red-500 text-xs hidden">Please select a training mode.</span>
    </div>

    <div class="flex flex-col gap-1">
      <label for={`${uid}-timing`} class="text-sm font-semibold text-[var(--color-ink)]">Preferred Timing</label>
      <select id={`${uid}-timing`} name="timing" class="w-full px-4 py-3 rounded-[var(--radius-input)] border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-ink)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-all appearance-none">
        <option value="" disabled selected>Select preferred timing</option>
        <option value="morning">Morning</option>
        <option value="evening">Evening</option>
        <option value="weekend">Weekend</option>
      </select>
    </div>

    <div class="flex flex-col gap-1">
      <label for={`${uid}-message`} class="text-sm font-semibold text-[var(--color-ink)]">Message</label>
      <textarea id={`${uid}-message`} name="message" rows="3" class="w-full px-4 py-3 rounded-[var(--radius-input)] border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-ink)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-all resize-y" placeholder="Any specific requirements?"></textarea>
    </div>
    
    <button type="submit" class="button primary w-full py-4 text-lg mt-2 flex justify-center items-center gap-2" data-enquiry-submit>
      <span class="btn-text" data-enquiry-btn-text>Send Enquiry</span>
      <svg class="spinner hidden animate-spin h-5 w-5 text-white" data-enquiry-spinner xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </button>
  </form>

  <div class="hidden absolute inset-0 bg-[var(--color-surface)] flex flex-col items-center justify-center text-center p-6 rounded-[var(--radius-card)] border border-green-200 bg-green-50" data-enquiry-success role="status" aria-live="polite">
    <div class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
    </div>
    <h3 class="text-xl font-bold text-green-800 mb-2">✅ Thank you!</h3>
    <p class="text-green-700">We'll contact you within 24 hours.</p>
    <button class="mt-6 text-green-700 font-medium hover:underline" type="button" data-enquiry-reset>Submit another enquiry</button>
  </div>
</div>

<script>
  const roots = document.querySelectorAll('[data-enquiry-root]');
  roots.forEach((root) => {
    const form = root.querySelector('form[data-enquiry-form]');
    const submitBtn = root.querySelector('button[data-enquiry-submit]');
    const btnText = submitBtn?.querySelector('[data-enquiry-btn-text]');
    const spinner = submitBtn?.querySelector('[data-enquiry-spinner]');
    const successMessage = /** @type {HTMLElement | null} */ (root.querySelector('[data-enquiry-success]'));
    const resetBtn = /** @type {HTMLButtonElement | null} */ (root.querySelector('button[data-enquiry-reset]'));

    if (form instanceof HTMLFormElement) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        let isValid = true;
        
        const inputs = form.querySelectorAll('input, select, textarea');
        inputs.forEach((input) => {
          const htmlInput = input;
          if (!(htmlInput instanceof HTMLInputElement || htmlInput instanceof HTMLSelectElement || htmlInput instanceof HTMLTextAreaElement)) return;
          const errorSpan = /** @type {HTMLElement | null} */ (htmlInput.nextElementSibling);
          if (htmlInput.hasAttribute('required') && !htmlInput.checkValidity()) {
            isValid = false;
            htmlInput.classList.add('border-red-500');
            if (errorSpan && errorSpan.classList.contains('error-message')) {
              errorSpan.classList.remove('hidden');
            }
          } else {
            htmlInput.classList.remove('border-red-500');
            if (errorSpan && errorSpan.classList.contains('error-message')) {
              errorSpan.classList.add('hidden');
            }
          }
        });

        if (isValid) {
          if (!(submitBtn instanceof HTMLButtonElement)) return;
          // Show loading state
          submitBtn.disabled = true;
          if (btnText) btnText.textContent = 'Sending...';
          if (spinner) spinner.classList.remove('hidden');

          // Submit to API
          const API_BASE = (typeof window !== 'undefined' && window.location.hostname !== 'localhost')
            ? `${window.location.protocol}//${window.location.hostname}:8000`
            : 'http://localhost:8000';

          const formData = new FormData(form);
          const payload = {
            name: formData.get('name'),
            email: formData.get('email'),
            phone: formData.get('phone'),
            course: formData.get('course'),
            mode: formData.get('mode'),
            timing: formData.get('timing') || null,
            message: formData.get('message') || null,
          };

          try {
            const res = await fetch(`${API_BASE}/api/enquiries/`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });

            if (!res.ok) {
              const err = await res.json().catch(() => null);
              throw new Error(err?.message || err?.detail || 'Submission failed');
            }

            form.classList.add('hidden');
            if (successMessage) successMessage.classList.remove('hidden');
            form.reset();
          } catch (err) {
            // Show inline error
            let errorDiv = form.querySelector('[data-enquiry-error]');
            if (!errorDiv) {
              errorDiv = document.createElement('div');
              errorDiv.setAttribute('data-enquiry-error', '');
              errorDiv.setAttribute('role', 'alert');
              errorDiv.className = 'text-red-600 text-sm font-medium bg-red-50 border border-red-200 rounded-lg p-3 mt-2';
              form.appendChild(errorDiv);
            }
            errorDiv.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
          } finally {
            submitBtn.disabled = false;
            if (btnText) btnText.textContent = 'Send Enquiry';
            if (spinner) spinner.classList.add('hidden');
          }
        }
      });

      const inputs = form.querySelectorAll('input, select, textarea');
      inputs.forEach((input) => {
        const htmlInput = input;
        if (!(htmlInput instanceof HTMLInputElement || htmlInput instanceof HTMLSelectElement || htmlInput instanceof HTMLTextAreaElement)) return;
        htmlInput.addEventListener('input', () => {
          const errorSpan = /** @type {HTMLElement | null} */ (htmlInput.nextElementSibling);
          if (htmlInput.checkValidity()) {
            htmlInput.classList.remove('border-red-500');
            if (errorSpan && errorSpan.classList.contains('error-message')) {
              errorSpan.classList.add('hidden');
            }
          }
        });
      });
    }

    if (resetBtn) {
      resetBtn.addEventListener('click', () => {
        if (successMessage) successMessage.classList.add('hidden');
        if (form) form.classList.remove('hidden');
      });
    }
  });
</script>
