---
import { Trophy, Users, BookOpen } from 'lucide-react';
import PlaceholderImage from './PlaceholderImage.astro';

const features = [
  {
    icon: Trophy,
    title: "expert-led instruction",
    description: "Learn from top-performing engineers who have just mastered the latest tech stacks and successfully cracked high-stakes technical interviews."
  },
  {
    icon: Users,
    title: "Peer-to-Peer Mentorship",
    description: "Get guidance from seniors who just cleared the same exams and interviews you’re preparing for, offering fresher-to-fresher insights that professors might miss."
  },
  {
    icon: BookOpen,
    title: "Open-Source Learning Hub",
    description: "Explore a constantly updated library of modern frameworks and tools, explained in the simple, everyday language of your peers."
  }
];
---
<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mt-12">
  <div class="order-2 lg:order-1">
    <PlaceholderImage label="[TEAM_PHOTO — 400x300px classroom/team image]" width={400} height={300} className="aspect-[4/3] w-full" />
  </div>
  <div class="order-1 lg:order-2 flex flex-col gap-8">
    {features.map(feature => (
      <div class="flex gap-6">
        <div class="w-14 h-14 rounded-2xl bg-[var(--color-primary)]/10 text-[var(--color-primary)] flex items-center justify-center shrink-0">
          <feature.icon class="w-7 h-7" />
        </div>
        <div>
          <h3 class="text-xl font-bold font-heading text-[var(--color-ink)] mb-2">{feature.title}</h3>
          <p class="text-[var(--color-muted)] leading-relaxed">{feature.description}</p>
        </div>
      </div>
    ))}
  </div>
</div>
