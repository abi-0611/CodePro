---
import { getLiveConsts } from '../utils/consts';
import ThemeToggle from './ThemeToggle.astro';

const liveConsts = await getLiveConsts();

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${baseUrl}${path.replace(/^\/+/, '')}`;

const navLinks = [
  { name: 'Home', href: withBase('') },
  { name: 'Courses', href: withBase('courses/') },
  { name: 'About Us', href: withBase('about/') },
  { name: 'Workshop', href: '#' },
  { name: 'Internship', href: '#' },
  { name: 'Contact Us', href: withBase('contact/') },
];

const currentPath = Astro.url.pathname;
const homeHref = withBase('');
const logoSrc = withBase('logo.png');
---

<header id="main-header" class="fixed top-[var(--banner-offset)] left-0 right-0 z-50 transition-all duration-300 bg-[var(--color-surface-val)]/80 backdrop-blur-md border-b border-[var(--color-border-val)]">
  <div id="scroll-progress" class="h-[3px] bg-gradient-to-r from-[var(--color-primary-val)] to-amber-400 fixed top-[var(--banner-offset)] left-0 z-[51] transition-none" style="width: 0%"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-20">
    
    {/* Logo */}
    <a href={homeHref} class="flex items-center gap-2 text-xl font-bold font-heading text-[var(--color-ink-val)]">
      <img src={logoSrc} alt={liveConsts.INSTITUTE_NAME} width="128" height="128" class="h-9 w-auto" loading="eager" decoding="async" />
      <span class="hidden sm:inline">{liveConsts.INSTITUTE_NAME}</span>
    </a>

    {/* Desktop Nav */}
    <nav class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <a 
          href={link.href} 
          class={`text-sm font-medium transition-colors hover:text-[var(--color-primary-val)] ${currentPath === link.href || (link.href !== homeHref && currentPath.startsWith(link.href)) ? 'text-[var(--color-primary-val)] font-semibold' : 'text-[var(--color-muted-val)]'}`}
        >
          {link.name}
        </a>
      ))}
    </nav>

    {/* Right Actions */}
    <div class="hidden md:flex items-center gap-4">
      <ThemeToggle />
      <div class="text-sm font-medium text-[var(--color-ink-val)] hidden lg:block">
        {liveConsts.CONTACT_PHONE}
      </div>
      <a href={withBase('contact/')} class="button primary text-sm py-2 px-4">
        Enquire Now
      </a>
    </div>

    {/* Mobile Menu Toggle */}
    <div class="flex items-center gap-4 md:hidden">
      <ThemeToggle />
      <button 
        id="mobile-menu-btn"
        class="flex flex-col justify-center items-center gap-1.5 w-10 h-10 md:hidden rounded-lg hover:bg-[var(--color-surface-alt-val)] transition-colors p-2"
        aria-label="Toggle navigation"
        aria-expanded="false"
      >
        <span class="ham-line" id="ham-1"></span>
        <span class="ham-line" id="ham-2"></span>
        <span class="ham-line" id="ham-3"></span>
      </button>
    </div>
  </div>

  {/* Mobile Nav */}
  <div id="mobile-menu" class="hidden md:hidden bg-[var(--color-surface-val)] border-b border-[var(--color-border-val)]">
    <nav class="flex flex-col px-4 py-4 gap-4 max-w-7xl mx-auto sm:px-6 lg:px-8">
      {navLinks.map(link => (
        <a 
          href={link.href} 
          class="text-base font-medium text-[var(--color-ink-val)] hover:text-[var(--color-primary-val)]"
        >
          {link.name}
        </a>
      ))}
      <div class="pt-4 border-t border-[var(--color-border-val)] flex flex-col gap-4">
        <div class="text-sm font-medium text-[var(--color-ink-val)]">
          {liveConsts.CONTACT_PHONE}
        </div>
        <a href={withBase('contact/')} class="button primary text-center w-full">
          Enquire Now
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('main-header');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const ham1 = document.getElementById('ham-1');
  const ham2 = document.getElementById('ham-2');
  const ham3 = document.getElementById('ham-3');
  const progressBar = document.getElementById('scroll-progress');

  // Scroll effect + progress bar
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      header?.classList.add('shadow-md');
    } else {
      header?.classList.remove('shadow-md');
    }

    if (progressBar) {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? Math.min(100, Math.max(0, (scrollTop / docHeight) * 100)) : 0;
      progressBar.style.width = `${progress}%`;
    }
  }, { passive: true });

  // Mobile menu toggle
  mobileBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    if (!mobileMenu) return;

    mobileMenu.classList.toggle('hidden');
    mobileBtn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');

    if (ham1 && ham2 && ham3) {
      if (!isOpen) {
        ham1.style.transform = 'translateY(5.5px) rotate(45deg)';
        ham2.style.opacity = '0';
        ham3.style.transform = 'translateY(-5.5px) rotate(-45deg)';
      } else {
        ham1.style.transform = '';
        ham2.style.opacity = '1';
        ham3.style.transform = '';
      }
    }
  });
</script>
