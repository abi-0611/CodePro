---
const { courseName } = Astro.props;

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---
<div id="sticky-cta" class="sticky-cta-bar md:hidden bg-[var(--color-surface-val)] border-t border-[var(--color-border-val)] px-4 py-3 shadow-2xl safe-area-bottom">
  <div class="flex items-center justify-between gap-3 max-w-sm mx-auto">
    <div class="min-w-0">
      <div class="text-xs font-semibold text-[var(--color-muted-val)] uppercase tracking-wider">Interested in</div>
      <div class="text-sm font-bold text-[var(--color-ink-val)] truncate">{courseName}</div>
    </div>
    <a href={`${baseUrl}contact/`} class="button primary px-5 py-3 text-sm button-shimmer">Enquire</a>
  </div>
</div>

<script>
  const bar = document.getElementById('sticky-cta');
  if (bar) {
    const trigger = 400;
    const onScroll = () => {
      if (window.scrollY > trigger) bar.classList.add('show');
      else bar.classList.remove('show');
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
