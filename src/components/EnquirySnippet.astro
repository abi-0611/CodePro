---
---
<section class="grid-overlay relative py-12 overflow-hidden border-y border-[var(--color-border-val)] bg-gradient-to-b from-[var(--enquiry-gradient-from-val)] to-[var(--enquiry-gradient-to-val)]" id="enquiry-section">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="md:w-1/3">
        <h2 class="text-2xl font-bold font-heading mb-2 text-[var(--color-ink-val)]">Want to know more?</h2>
        <p class="text-[var(--color-muted-val)]">Drop your details and we'll call you back.</p>
      </div>
      
      <form id="snippet-form" class="w-full md:w-2/3 flex flex-col sm:flex-row sm:flex-wrap gap-4" novalidate>
        <div class="flex-1 min-w-0 relative">
          <label for="snippet-name" class="sr-only">Your Name</label>
          <input type="text" id="snippet-name" required placeholder="Your Name" class="w-full px-4 py-3 rounded-full bg-[var(--color-surface-val)] border border-[var(--color-border-val)] text-[var(--color-ink-val)] placeholder:text-[var(--color-muted-val)] focus:outline-none focus:border-[var(--color-primary-val)] transition-all" />
          <span class="error-message text-red-400 text-xs absolute -bottom-5 left-4 hidden">Required</span>
        </div>
        <div class="flex-1 min-w-0 relative">
          <label for="snippet-phone" class="sr-only">Phone Number</label>
          <input type="tel" id="snippet-phone" required pattern="[0-9]{10}" placeholder="Phone Number" class="w-full px-4 py-3 rounded-full bg-[var(--color-surface-val)] border border-[var(--color-border-val)] text-[var(--color-ink-val)] placeholder:text-[var(--color-muted-val)] focus:outline-none focus:border-[var(--color-primary-val)] transition-all" />
          <span class="error-message text-red-400 text-xs absolute -bottom-5 left-4 hidden">Valid 10-digit number</span>
        </div>
        <button type="submit" class="button primary w-full sm:w-auto whitespace-nowrap rounded-full px-8">
          Call Me Back
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  const snippetForm = /** @type {HTMLFormElement | null} */ (document.getElementById('snippet-form'));
  if (snippetForm) {
    snippetForm.addEventListener('submit', (e) => {
      e.preventDefault();
      let isValid = true;
      
      const inputs = snippetForm.querySelectorAll('input');
      inputs.forEach((input) => {
        const htmlInput = /** @type {HTMLInputElement} */ (input);
        const errorSpan = /** @type {HTMLElement | null} */ (htmlInput.nextElementSibling);
        if (!htmlInput.checkValidity()) {
          isValid = false;
          htmlInput.classList.add('border-red-400');
          if (errorSpan) errorSpan.classList.remove('hidden');
        } else {
          htmlInput.classList.remove('border-red-400');
          if (errorSpan) errorSpan.classList.add('hidden');
        }
      });

      if (isValid) {
        const btn = /** @type {HTMLButtonElement | null} */ (snippetForm.querySelector('button[type="submit"]'));
        if (!btn) return;
        const originalText = btn.textContent;
        btn.textContent = 'Sent!';
        btn.classList.add('bg-green-500');
        setTimeout(() => {
          btn.textContent = originalText;
          btn.classList.remove('bg-green-500');
        }, 3000);
        snippetForm.reset();
      }
    });

    const inputs = snippetForm.querySelectorAll('input');
    inputs.forEach((input) => {
      const htmlInput = /** @type {HTMLInputElement} */ (input);
      htmlInput.addEventListener('input', () => {
        const errorSpan = /** @type {HTMLElement | null} */ (htmlInput.nextElementSibling);
        if (htmlInput.checkValidity()) {
          htmlInput.classList.remove('border-red-400');
          if (errorSpan) errorSpan.classList.add('hidden');
        }
      });
    });
  }
</script>
