---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
import PlaceholderImage from '../components/PlaceholderImage.astro';
import { MapPin, Phone, Mail, Instagram, Facebook, Youtube, Linkedin, Calendar, Download, MessageCircle } from 'lucide-react';
import { getLiveConsts } from '../utils/consts';

const lc = await getLiveConsts();

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const isUsableUrl = (value: unknown) =>
  typeof value === 'string' && /^https?:\/\//.test(value.trim());

const phone = typeof lc.CONTACT_PHONE === 'string' && lc.CONTACT_PHONE.trim() ? lc.CONTACT_PHONE : null;
const email = typeof lc.CONTACT_EMAIL === 'string' && lc.CONTACT_EMAIL.trim() ? lc.CONTACT_EMAIL : null;
const address = typeof lc.ADDRESS_PLACEHOLDER === 'string' && lc.ADDRESS_PLACEHOLDER.trim() ? lc.ADDRESS_PLACEHOLDER : null;

const mapsUrl = isUsableUrl(lc.GOOGLE_MAPS_URL) ? lc.GOOGLE_MAPS_URL : null;
const brochureUrl = isUsableUrl(lc.BROCHURE_PDF_URL) ? lc.BROCHURE_PDF_URL : null;
const whatsappUrl = isUsableUrl(lc.WHATSAPP_URL) ? lc.WHATSAPP_URL : null;

const socials = [
  { label: 'Instagram', icon: Instagram, href: isUsableUrl(lc.SOCIAL_INSTAGRAM_URL) ? lc.SOCIAL_INSTAGRAM_URL : null },
  { label: 'Facebook', icon: Facebook, href: isUsableUrl(lc.SOCIAL_FACEBOOK_URL) ? lc.SOCIAL_FACEBOOK_URL : null },
  { label: 'YouTube', icon: Youtube, href: isUsableUrl(lc.SOCIAL_YOUTUBE_URL) ? lc.SOCIAL_YOUTUBE_URL : null },
  { label: 'LinkedIn', icon: Linkedin, href: isUsableUrl(lc.SOCIAL_LINKEDIN_URL) ? lc.SOCIAL_LINKEDIN_URL : null },
].filter((s) => s.href);
---

<BaseLayout title="Contact" description="Talk to our team and get course guidance, batch details, and fee information.">
  <div class="pt-32 pb-20">
    <SectionHeader 
      eyebrow="Contact"
      title="Let’s plan your learning path"
      description="Share what you want to learn, and we’ll suggest the right course, next batch schedule, and a clear roadmap to get started."
      align="center"
    />
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 mt-12 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      {/* Contact Info (60%) */}
      <div class="lg:col-span-7 flex flex-col gap-10">
        <div class="flex flex-col gap-6">
          <div class="card p-6 flex items-start gap-4 reveal">
            <div class="w-12 h-12 rounded-full bg-[var(--color-surface-alt-val)] flex items-center justify-center text-[var(--color-primary-val)] shrink-0">
              <MapPin class="w-6 h-6" />
            </div>
            <div>
              <h4 class="font-bold text-[var(--color-ink-val)] mb-2">Visit our center</h4>
              <p class="text-[var(--color-muted-val)] mb-3">{address ?? 'Enquire to get the exact center location and directions.'}</p>
              {mapsUrl && (
                <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="text-[var(--color-primary-val)] font-medium hover:underline flex items-center gap-1">
                  Get directions
                </a>
              )}
            </div>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="card p-6 flex flex-col gap-4 reveal">
              <div class="w-12 h-12 rounded-full bg-[var(--color-surface-alt-val)] flex items-center justify-center text-[var(--color-primary-val)] shrink-0">
                <Phone class="w-6 h-6" />
              </div>
              <div>
                <h4 class="font-bold text-[var(--color-ink-val)] mb-1">Call us</h4>
                {phone ? (
                  <p class="text-[var(--color-muted-val)]">Speak to our team: <a class="text-[var(--color-primary-val)] font-medium hover:underline" href={`tel:${phone}`}>{phone}</a></p>
                ) : (
                  <p class="text-[var(--color-muted-val)]">Share your number in the form and we’ll call you back.</p>
                )}
              </div>
            </div>
            
            <div class="card p-6 flex flex-col gap-4 reveal">
              <div class="w-12 h-12 rounded-full bg-[var(--color-surface-alt-val)] flex items-center justify-center text-[var(--color-primary-val)] shrink-0">
                <Mail class="w-6 h-6" />
              </div>
              <div>
                <h4 class="font-bold text-[var(--color-ink-val)] mb-1">Email</h4>
                {email ? (
                  <p class="text-[var(--color-muted-val)]">Write to us at <a class="text-[var(--color-primary-val)] font-medium hover:underline" href={`mailto:${email}`}>{email}</a></p>
                ) : (
                  <p class="text-[var(--color-muted-val)]">Use the form to send your questions.</p>
                )}
              </div>
            </div>
          </div>

          <div class="card p-6 reveal">
            <h4 class="font-bold text-[var(--color-ink-val)] mb-2">Working hours</h4>
            <p class="text-[var(--color-muted-val)]">{lc.WORKING_HOURS || 'Contact us to confirm batch timings and availability.'}</p>
          </div>
        </div>

        {/* Map Placeholder */}
        <PlaceholderImage label="Google Maps embed (optional)" width={1200} height={400} className="w-full h-[400px] !rounded-[var(--radius-card)]" />

        {/* Social Media Links */}
        {socials.length > 0 && (
          <div>
            <h4 class="font-bold text-[var(--color-ink-val)] mb-4">Follow us</h4>
            <div class="flex flex-wrap gap-4">
              {socials.map((s) => (
                <a href={s.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-border-val)] hover:border-[var(--color-primary-val)] hover:text-[var(--color-primary-val)] transition-colors">
                  <s.icon class="w-5 h-5" />
                  <span>{s.label}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      {/* Contact Form (40%) */}
      <div class="lg:col-span-5">
        <div id="contact-form" class="card p-8 sticky top-24 reveal-right">
          <h3 class="text-2xl font-bold font-heading text-[var(--color-ink-val)] mb-6">Send an enquiry</h3>
          <EnquiryForm />
        </div>
      </div>
      
    </div>

    {/* Quick Links Section */}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-24">
      <h3 class="text-2xl font-bold font-heading text-[var(--color-ink-val)] mb-8 text-center">Quick actions</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="#contact-form" class="reveal delay-1 card-lift card p-8 flex flex-col items-center text-center gap-4 hover:-translate-y-1 transition-transform group">
          <div class="w-16 h-16 rounded-full bg-[var(--color-surface-alt-val)] flex items-center justify-center text-[var(--color-primary-val)] group-hover:scale-110 transition-transform">
            <Calendar class="w-8 h-8" />
          </div>
          <h4 class="font-bold text-lg text-[var(--color-ink-val)]">Book a callback</h4>
          <p class="text-[var(--color-muted-val)] text-sm">Tell us your course interest and preferred time.</p>
        </a>
        
        {brochureUrl ? (
          <a href={brochureUrl} target="_blank" rel="noopener noreferrer" class="reveal delay-2 card-lift card p-8 flex flex-col items-center text-center gap-4 hover:-translate-y-1 transition-transform group">
            <div class="w-16 h-16 rounded-full bg-[var(--color-surface-alt-val)] flex items-center justify-center text-[var(--color-primary-val)] group-hover:scale-110 transition-transform">
              <Download class="w-8 h-8" />
            </div>
            <h4 class="font-bold text-lg text-[var(--color-ink-val)]">Download brochure</h4>
            <p class="text-[var(--color-muted-val)] text-sm">Get the complete syllabus and course overview.</p>
          </a>
        ) : (
          <a href={`${baseUrl}courses/`} class="reveal delay-2 card-lift card p-8 flex flex-col items-center text-center gap-4 hover:-translate-y-1 transition-transform group">
            <div class="w-16 h-16 rounded-full bg-[var(--color-surface-alt-val)] flex items-center justify-center text-[var(--color-primary-val)] group-hover:scale-110 transition-transform">
              <Download class="w-8 h-8" />
            </div>
            <h4 class="font-bold text-lg text-[var(--color-ink-val)]">Explore courses</h4>
            <p class="text-[var(--color-muted-val)] text-sm">See curriculum, duration, and learning outcomes.</p>
          </a>
        )}
        
        {whatsappUrl ? (
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="reveal delay-3 card-lift card p-8 flex flex-col items-center text-center gap-4 hover:-translate-y-1 transition-transform group">
            <div class="w-16 h-16 rounded-full bg-[var(--color-surface-alt-val)] flex items-center justify-center text-[var(--color-primary-val)] group-hover:scale-110 transition-transform">
              <MessageCircle class="w-8 h-8" />
            </div>
            <h4 class="font-bold text-lg text-[var(--color-ink-val)]">Chat on WhatsApp</h4>
            <p class="text-[var(--color-muted-val)] text-sm">Quick questions? Get fast guidance from our team.</p>
          </a>
        ) : (
          <a href="#contact-form" class="reveal delay-3 card-lift card p-8 flex flex-col items-center text-center gap-4 hover:-translate-y-1 transition-transform group">
            <div class="w-16 h-16 rounded-full bg-[var(--color-surface-alt-val)] flex items-center justify-center text-[var(--color-primary-val)] group-hover:scale-110 transition-transform">
              <MessageCircle class="w-8 h-8" />
            </div>
            <h4 class="font-bold text-lg text-[var(--color-ink-val)]">Ask a question</h4>
            <p class="text-[var(--color-muted-val)] text-sm">Send your query and we’ll get back shortly.</p>
          </a>
        )}
      </div>
    </div>

  </div>
</BaseLayout>
