---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroAnimated from '../components/HeroAnimated.astro';
import StatBar from '../components/StatBar.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CourseCard from '../components/CourseCard.astro';
import CoursesCarousel from '../components/CoursesCarousel.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import TestimonialsGrid from '../components/TestimonialsGrid.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
import { getAllCourses, getSiteConfig, getContent, getContentJson } from '../lib/api';

const [allCourses, config] = await Promise.all([getAllCourses(), getSiteConfig()]);
const featuredCourses = allCourses.slice(0, 3);

const section1Eyebrow = getContent(config, 'home', 'section1_eyebrow', 'Top Courses');
const section1Title = getContent(config, 'home', 'section1_title', 'Start with our most popular programs');
const section1Description = getContent(config, 'home', 'section1_description', 'Hands-on, mentor-led courses designed for beginners and working professionals.');
const section1Cta = getContent(config, 'home', 'section1_cta_text', 'View All Courses');

const section2Eyebrow = getContent(config, 'home', 'section2_eyebrow', 'All Programs');
const section2Title = getContent(config, 'home', 'section2_title', 'Explore every course');

const enquiryHeadline = getContent(config, 'home', 'enquiry_headline', 'Not sure which course is right for you?');
const enquiryDescription = getContent(config, 'home', 'enquiry_description', 'Talk to our mentors for free. We\'ll help you pick the right course, explain the syllabus, and plan a roadmap based on your goals and current level.');
const enquiryBullets = getContentJson<string[]>(config, 'home', 'enquiry_bullets', [
  'Free 15-minute consultation call',
  'No pushy sales — just honest guidance',
  'Get a learning roadmap tailored for you',
  'Flexible batch options explained clearly',
]);

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Home" description="Job-focused tech training with hands-on projects, mentorship, and placement support.">
  <HeroAnimated />

  <StatBar wrapperClass="bg-[var(--color-surface-val)]" />

  <!-- Featured Courses (3 cards) -->
  <section id="courses-section" class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="reveal">
        <SectionHeader
          eyebrow={section1Eyebrow}
          title={section1Title}
          description={section1Description}
        />
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-2">
        {featuredCourses.map((course: any, i: number) => (
          <div class={`reveal delay-${i+1} card-lift`}>
            <CourseCard
              title={course.title}
              shortDescription={course.short_description}
              duration={course.duration}
              mode={course.mode}
              level={course.level}
              slug={course.slug}
              badge={course.badge}
              icon={course.icon}
              category={course.category}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- All Courses Carousel -->
  <section class="py-16 bg-[var(--color-surface-alt-val)] border-y border-[var(--color-border-val)] overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8 reveal">
        <div>
          <span class="eyebrow">✦ {section2Eyebrow}</span>
          <h2 class="text-3xl font-bold font-heading text-[var(--color-ink-val)] mt-2">{section2Title}</h2>
        </div>
        <a href={`${baseUrl}courses/`} class="button secondary hidden sm:inline-flex">{section1Cta} →</a>
      </div>
      <CoursesCarousel />
      <div class="text-center mt-8 sm:hidden">
        <a href={`${baseUrl}courses/`} class="button secondary">View All Courses →</a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us (tabbed) -->
  <WhyChooseUs />

  <!-- Process Steps -->
  <ProcessSteps />

  <!-- Testimonials -->
  <TestimonialsGrid />

  <!-- FAQ -->
  <FaqAccordion />

  <!-- Enquiry CTA Section -->
  <section id="enquiry-section" class="py-24 bg-gradient-to-br from-[var(--color-primary-val)] to-amber-600 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" aria-hidden="true">
      <div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-white blur-[80px]"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full bg-white blur-[60px]"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="text-white reveal">
          <span class="text-white/70 font-semibold uppercase tracking-wider text-sm">✦ Free Consultation</span>
          <h2 class="text-4xl md:text-5xl font-bold font-heading mt-3 mb-6 leading-tight">
            {enquiryHeadline}
          </h2>
          <p class="text-white/80 text-lg leading-relaxed mb-8">
            {enquiryDescription}
          </p>
          <ul class="space-y-3">
            {enquiryBullets.map(item => (
              <li class="flex items-center gap-3 text-white/90">
                <span class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center text-xs">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="reveal delay-2">
          <div class="card p-8 bg-[var(--color-surface-val)] shadow-2xl">
            <h3 class="text-2xl font-bold font-heading text-[var(--color-ink-val)] mb-2">Send an Enquiry</h3>
            <p class="text-[var(--color-muted-val)] text-sm mb-6">We'll call you back within 24 hours.</p>
            <EnquiryForm />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
