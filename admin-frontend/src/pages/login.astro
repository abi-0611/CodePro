---
import { isAuthenticated } from '../lib/auth';

if (isAuthenticated(Astro.cookies)) {
  return Astro.redirect('/admin/dashboard');
}

const errorParam = Astro.url.searchParams.get('error') || '';
const redirectParam = Astro.url.searchParams.get('redirect') || '/admin/dashboard';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Login — CodePro Admin</title>
    <link rel="stylesheet" href="/admin/src/styles/admin.css" />
    <style>
      /* ── Page layout ── */
      .login-page {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
        background-color: var(--color-paper);
      }
      @media (max-width: 768px) {
        .login-page { grid-template-columns: 1fr; }
        .login-left  { display: none; }
      }

      /* ── Left hero panel ── */
      .login-left {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        padding: 3rem;
        color: white;
      }

      /* Animated gradient orbs */
      .login-left::before {
        content: '';
        position: absolute;
        top: -120px;
        right: -120px;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(180,83,9,0.30) 0%, transparent 70%);
        animation: admin-float-slow 8s ease-in-out infinite;
        pointer-events: none;
      }

      .login-left::after {
        content: '';
        position: absolute;
        bottom: -80px;
        left: -80px;
        width: 400px;
        height: 400px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(59,130,246,0.20) 0%, transparent 70%);
        animation: admin-float 6s ease-in-out 1s infinite;
        pointer-events: none;
      }

      /* Grid overlay on left panel */
      .login-left-grid {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
        background-size: 48px 48px;
        pointer-events: none;
      }

      .login-left-content {
        position: relative;
        z-index: 2;
        text-align: center;
      }

      .login-left-logo {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        background: linear-gradient(135deg, #fff 0%, #fbbf24 60%, #fff 100%);
        background-size: 200% auto;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: admin-gradient-shift 4s ease infinite;
      }

      .login-left-tagline {
        font-size: 1rem;
        opacity: 0.75;
        margin-bottom: 3rem;
        letter-spacing: 0.02em;
      }

      .login-float-cards {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        justify-content: center;
        animation: admin-fade-up 0.8s var(--ease-spring) 0.4s both;
      }

      .login-float-card {
        background: rgba(255,255,255,0.09);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.14);
        border-radius: 14px;
        padding: 0.875rem 1.375rem;
        font-size: 0.85rem;
        font-weight: 500;
        transition: transform 0.2s ease, background 0.2s ease;
      }

      .login-float-card:hover {
        transform: translateY(-4px);
        background: rgba(255,255,255,0.14);
      }

      /* ── Right panel ── */
      .login-right {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        background: var(--color-paper);
        position: relative;
      }

      /* ── Login card ── */
      .login-card {
        width: 100%;
        max-width: 420px;
        background: var(--glass-bg);
        background-image: linear-gradient(135deg, var(--glass-highlight), transparent 55%);
        border-radius: var(--radius-card);
        box-shadow: var(--shadow-card-hover);
        border: 1px solid var(--glass-border);
        backdrop-filter: blur(22px) saturate(165%);
        -webkit-backdrop-filter: blur(22px) saturate(165%);
        padding: 2.5rem;
        animation: admin-bounce-in 0.6s var(--ease-spring) both;
      }

      .login-title {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.25rem;
        letter-spacing: -0.02em;
      }

      .login-subtitle {
        font-size: 0.875rem;
        color: var(--text-secondary);
        margin-bottom: 2rem;
      }

      /* ── Form fields ── */
      .login-field {
        margin-bottom: 1.25rem;
      }

      .login-field label {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
        margin-bottom: 0.4rem;
        color: var(--text-primary);
      }

      .login-field .input-wrap {
        position: relative;
      }

      .login-field .input-wrap .icon {
        position: absolute;
        left: 0.875rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.95rem;
        opacity: 0.45;
        pointer-events: none;
      }

      .login-field input {
        width: 100%;
        padding: 0.7rem 0.875rem 0.7rem 2.5rem;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-input);
        background: var(--color-surface);
        color: var(--text-primary);
        font-size: 0.9rem;
        transition: border-color var(--duration-fast) ease,
                    box-shadow    var(--duration-fast) ease;
        box-sizing: border-box;
      }

      .login-field input:focus {
        outline: none;
        border-color: var(--color-primary);
        box-shadow: 0 0 0 3px rgba(var(--color-primary-rgb), 0.14);
      }

      /* ── Submit button ── */
      .login-btn {
        width: 100%;
        padding: 0.8rem;
        border-radius: var(--radius-pill);
        background: var(--color-primary);
        color: #fff;
        border: none;
        font-weight: 700;
        font-size: 0.95rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        position: relative;
        overflow: hidden;
        transition: background var(--duration-fast) ease,
                    transform   var(--duration-fast) ease,
                    box-shadow  var(--duration-fast) ease;
      }

      .login-btn::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.22) 50%, transparent 60%);
        background-size: 200% 100%;
        animation: admin-shimmer 2.5s infinite;
        pointer-events: none;
      }

      .login-btn:hover {
        background: var(--color-primary-dark);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(var(--color-primary-rgb), 0.42);
      }

      .login-btn:active { transform: translateY(0); }

      .login-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
      }

      /* ── Error box ── */
      .login-error {
        margin-top: 1rem;
        padding: 0.75rem;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 10px;
        color: #dc2626;
        font-size: 0.8rem;
        display: none;
      }
      .login-error.visible { display: block; }

      /* ── Remember row ── */
      .remember-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.25rem;
      }
      .remember-row input[type="checkbox"] {
        width: 1rem;
        height: 1rem;
        accent-color: var(--color-primary);
        cursor: pointer;
      }
      .remember-row label {
        font-size: 0.8rem;
        color: var(--text-secondary);
        cursor: pointer;
        user-select: none;
      }

      /* ── Show/hide password button ── */
      .toggle-password {
        position: absolute;
        right: 0.875rem;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        font-size: 0.8rem;
        opacity: 0.45;
        transition: opacity var(--duration-fast) ease;
      }
      .toggle-password:hover { opacity: 0.85; }

      /* ── Footer text ── */
      .login-footer {
        margin-top: 2rem;
        text-align: center;
        font-size: 0.7rem;
        color: var(--text-secondary);
      }

      /* ── Shake on bad credentials ── */
      @keyframes shake {
        0%, 100% { transform: translateX(0); }
        20%, 60%  { transform: translateX(-8px); }
        40%, 80%  { transform: translateX(8px); }
      }
      .shake { animation: shake 0.38s ease; }
    </style>
  </head>
  <body>
    <div class="login-page">
      <div class="login-left">
        <div class="login-left-grid" aria-hidden="true"></div>
        <div class="login-left-content">
          <div class="login-left-logo">⚡ CodePro.io</div>
          <div class="login-left-tagline">Admin Control Center</div>
          <div class="login-float-cards">
            <div class="login-float-card">📚 8 Courses</div>
            <div class="login-float-card">🔄 Live Updates</div>
            <div class="login-float-card">🔒 Secure CMS</div>
          </div>
        </div>
      </div>

      <div class="login-right">
        <div class="login-card" id="login-card">
          <h1 class="login-title">Welcome back</h1>
          <p class="login-subtitle">Sign in to manage your content</p>

          <form id="login-form" autocomplete="on">
            <div class="login-field">
              <label for="username">Username</label>
              <div class="input-wrap">
                <span class="icon">👤</span>
                <input
                  type="text"
                  id="username"
                  name="username"
                  autocomplete="username"
                  placeholder="Enter your username"
                  required
                  minlength="3"
                />
              </div>
            </div>

            <div class="login-field">
              <label for="password">Password</label>
              <div class="input-wrap">
                <span class="icon">🔒</span>
                <input
                  type="password"
                  id="password"
                  name="password"
                  autocomplete="current-password"
                  placeholder="Enter your password"
                  required
                />
                <button type="button" class="toggle-password" id="toggle-pw" aria-label="Toggle password visibility">
                  👁
                </button>
              </div>
            </div>

            <div class="remember-row">
              <input type="checkbox" id="remember" name="remember" />
              <label for="remember">Remember me for 7 days</label>
            </div>

            <button type="submit" class="login-btn" id="login-btn">
              Sign In
            </button>

            <div class="login-error" id="login-error"></div>
          </form>

          <div class="login-footer">CodePro.io Admin &bull; v1.0</div>
        </div>
      </div>
    </div>

    <script define:vars={{ errorParam, redirectParam }}>
      const form = document.getElementById('login-form');
      const btn = document.getElementById('login-btn');
      const errorEl = document.getElementById('login-error');
      const card = document.getElementById('login-card');
      const togglePw = document.getElementById('toggle-pw');
      const pwInput = document.getElementById('password');

      // Show initial error from query param
      if (errorParam) {
        errorEl.textContent = errorParam;
        errorEl.classList.add('visible');
      }

      // Toggle password visibility
      togglePw?.addEventListener('click', () => {
        const type = pwInput.type === 'password' ? 'text' : 'password';
        pwInput.type = type;
        togglePw.textContent = type === 'password' ? '👁' : '🙈';
      });

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const username = form.username.value.trim();
        const password = form.password.value;
        const remember = document.getElementById('remember')?.checked || false;

        if (username.length < 3) {
          showError('Username must be at least 3 characters');
          return;
        }

        btn.disabled = true;
        btn.innerHTML = '<span class="admin-spinner"></span> Signing in…';
        errorEl.classList.remove('visible');

        try {
          const res = await fetch('/admin/api/admin-auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username, password, remember }),
          });
          const data = await res.json();

          if (res.ok && data.success) {
            window.location.href = redirectParam || '/admin/dashboard';
          } else {
            showError(data.error || 'Invalid credentials');
            form.password.value = '';
            card.classList.add('shake');
            setTimeout(() => card.classList.remove('shake'), 400);
          }
        } catch {
          showError('Network error. Please try again.');
        } finally {
          btn.disabled = false;
          btn.innerHTML = 'Sign In';
        }
      });

      function showError(msg) {
        errorEl.textContent = msg;
        errorEl.classList.add('visible');
      }
    </script>
  </body>
</html>
