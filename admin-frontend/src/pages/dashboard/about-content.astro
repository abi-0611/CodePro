---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getTokenFromCookies } from '../../lib/auth';
import AboutContentEditor from '../../components/content/AboutContentEditor';

const API_BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
const token = getTokenFromCookies(Astro.cookies);
if (!token) return Astro.redirect('/admin/login');

let aboutContent: Record<string, any> = {};

try {
  const res = await fetch(`${API_BASE}/api/content/all`);
  if (res.ok) {
    const data = await res.json();
    aboutContent = data.about || {};
  }
} catch { /* fallback to empty */ }
---

<AdminLayout title="About Page Content">
  <div style="display:flex;flex-direction:column;gap:1.5rem;max-width:860px">
    <nav style="font-size:0.8rem;color:var(--text-secondary)">
      <a href="/admin/dashboard" style="color:var(--color-primary);text-decoration:none">Dashboard</a>
      <span style="margin:0 0.5rem">›</span>
      <span>About Page Content</span>
    </nav>

    <h1 style="font-size:1.5rem;font-weight:700;font-family:'Space Grotesk',sans-serif;margin:0">About Page Content</h1>
    <p style="font-size:0.85rem;color:var(--text-secondary);margin-top:-0.75rem">Edit about page copy, team info, and story sections</p>

    <AboutContentEditor client:load initialData={{ about: aboutContent }} />
  </div>
</AdminLayout>
