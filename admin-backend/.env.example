# Database — Neon DB (asyncpg format)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

# Security
SECRET_KEY=change-me-to-a-64-char-random-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Initial admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-bcrypt-hashed-password

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:4322"]

# Environment
APP_ENV=development

# Redis (for rate limiting — shared across workers)
REDIS_URL=redis://localhost:6379/0
